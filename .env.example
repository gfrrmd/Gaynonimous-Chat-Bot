# Token dari @BotFather
BOT_TOKEN=your_bot_token_here

# ID admin (pisahkan dengan koma untuk beberapa admin)
ADMIN_IDS=123456789,987654321

# PostgreSQL Railway (otomatis diisi oleh Railway)
# Kosongkan untuk gunakan SQLite lokal
DATABASE_URL=

# Timeout approval media dalam detik (default: 60)
MEDIA_APPROVAL_TIMEOUT=60

# Level log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
